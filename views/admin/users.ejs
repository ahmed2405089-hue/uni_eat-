<script src="/js/admin.js"></script>

<div class="page-header__row" data-anim>
  <div class="page-header">
    <h1 class="page-title">Users</h1>
    <p class="page-subtitle">Manage all platform users</p>
  </div>
</div>

<div class="filter-row" data-anim>
  <div class="search-box" style="flex:1;max-width:360px">
    <i class="fa-solid fa-magnifying-glass"></i>
    <input type="text" class="form-control" id="user-search" placeholder="Search by name or email…" />
  </div>
  <select class="form-control" id="role-filter" style="width:auto">
    <option value="">All Roles</option>
    <option value="student">Student</option>
    <option value="owner">Owner</option>
    <option value="admin">Admin</option>
  </select>
</div>

<% if (users.length === 0) { %>
  <div class="empty-state" data-anim>
    <i class="fa-solid fa-users-slash"></i>
    <h3>No Users Found</h3>
  </div>
<% } else { %>
  <div class="table-wrap" data-anim>
    <table class="table" id="users-table">
      <thead>
        <tr>
          <th>User</th>
          <th>Role</th>
          <th>Status</th>
          <th>Joined</th>
          <th>Last Login</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr data-name="<%= u.name.toLowerCase() %>" data-email="<%= u.email.toLowerCase() %>" data-role="<%= u.role %>">
            <td>
              <div class="user-info">
                <div class="user-avatar"><%= u.name.charAt(0).toUpperCase() %></div>
                <div>
                  <div style="font-weight:600;font-size:var(--text-sm)"><%= u.name %></div>
                  <div style="font-size:var(--text-xs);color:var(--clr-text-muted)"><%= u.email %></div>
                </div>
              </div>
            </td>
            <td><span class="badge badge--<%= u.role %>"><%= u.role %></span></td>
            <td>
              <span class="badge badge--<%= u.isActive ? 'ready' : 'cancelled' %>">
                <%= u.isActive ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td style="font-size:var(--text-sm)"><%= new Date(u.createdAt).toLocaleDateString() %></td>
            <td style="font-size:var(--text-sm);color:var(--clr-text-muted)">
              <%= u.lastLogin ? new Date(u.lastLogin).toLocaleDateString() : 'Never' %>
            </td>
            <td>
              <div style="display:flex;gap:var(--sp-2)">
                <button class="btn btn--ghost btn--icon-sm edit-user-btn"
                  data-id="<%= u._id %>" data-name="<%= u.name %>"
                  data-role="<%= u.role %>" data-active="<%= u.isActive %>" title="Edit">
                  <i class="fa-solid fa-pen" style="font-size:var(--text-xs)"></i>
                </button>
                <button class="btn btn--ghost btn--icon-sm delete-user-btn"
                  data-id="<%= u._id %>" data-name="<%= u.name %>" title="Delete"
                  style="color:var(--clr-danger)">
                  <i class="fa-solid fa-trash" style="font-size:var(--text-xs)"></i>
                </button>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<!-- Edit User Modal -->
<div class="modal-backdrop" id="user-modal">
  <div class="modal">
    <div class="modal__header">
      <h2 class="modal__title">Edit User</h2>
      <span class="modal__close" id="close-user-modal"><i class="fa-solid fa-xmark"></i></span>
    </div>
    <form id="user-form">
      <input type="hidden" id="user-modal-id" />
      <div class="form-group">
        <label class="form-label">Full Name</label>
        <input type="text" class="form-control" id="user-name" required />
      </div>
      <div class="form-group">
        <label class="form-label">Role</label>
        <select class="form-control" id="user-role">
          <option value="student">Student</option>
          <option value="owner">Owner</option>
          <option value="admin">Admin</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Status</label>
        <select class="form-control" id="user-active">
          <option value="true">Active</option>
          <option value="false">Inactive</option>
        </select>
      </div>
      <div style="display:flex;gap:var(--sp-3);justify-content:flex-end;margin-top:var(--sp-4)">
        <button type="button" class="btn btn--ghost" id="cancel-user-modal">Cancel</button>
        <button type="submit" class="btn btn--primary">Save Changes</button>
      </div>
    </form>
  </div>
</div>
