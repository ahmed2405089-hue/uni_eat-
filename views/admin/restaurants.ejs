<script src="/js/admin.js"></script>

<div class="page-header__row" data-anim>
  <div class="page-header">
    <h1 class="page-title">Restaurants</h1>
    <p class="page-subtitle">Create, edit, assign, and remove restaurants</p>
  </div>
  <button class="btn btn--primary" id="add-restaurant-btn">
    <i class="fa-solid fa-plus"></i> Add Restaurant
  </button>
</div>

<div class="filter-row" data-anim>
  <div class="search-box" style="flex:1;max-width:360px">
    <i class="fa-solid fa-magnifying-glass"></i>
    <input type="text" class="form-control" id="rest-search" placeholder="Search restaurants…" />
  </div>
</div>

<% if (restaurants.length === 0) { %>
  <div class="empty-state" data-anim>
    <i class="fa-solid fa-store-slash"></i>
    <h3>No Restaurants</h3>
    <p>Click "Add Restaurant" to create the first one.</p>
  </div>
<% } else { %>
  <div class="table-wrap" data-anim>
    <table class="table" id="restaurants-table">
      <thead>
        <tr>
          <th>Restaurant</th>
          <th>Owner</th>
          <th>Rating</th>
          <th>Delivery</th>
          <th>Status</th>
          <th>Approved</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% restaurants.forEach(r => { %>
          <tr data-name="<%= r.name.toLowerCase() %>">
            <td>
              <div style="display:flex;align-items:center;gap:var(--sp-3)">
                <div style="width:40px;height:40px;border-radius:var(--r-md);background:var(--clr-bg-3);overflow:hidden;flex-shrink:0">
                  <% if (r.image) { %><img src="<%= r.image %>" style="width:100%;height:100%;object-fit:cover"/><% } else { %>
                    <div style="width:100%;height:100%;display:grid;place-items:center">🍽️</div>
                  <% } %>
                </div>
                <span style="font-weight:600"><%= r.name %></span>
              </div>
            </td>
            <td>
              <% if (r.owner) { %>
                <div style="font-size:var(--text-sm)"><%= r.owner.name %></div>
                <div style="font-size:var(--text-xs);color:var(--clr-text-muted)"><%= r.owner.email %></div>
              <% } else { %>
                <span style="color:var(--clr-text-muted);font-size:var(--text-sm)">Unassigned</span>
              <% } %>
            </td>
            <td><span style="color:var(--clr-warning)">★</span> <%= r.rating.toFixed(1) %></td>
            <td><%= r.deliveryTime %></td>
            <td>
              <span class="badge badge--<%= r.isOpen ? 'ready' : 'cancelled' %>">
                <%= r.isOpen ? 'Open' : 'Closed' %>
              </span>
            </td>
            <td>
              <span class="badge badge--<%= r.isApproved ? 'ready' : 'warning' %>">
                <%= r.isApproved ? 'Approved' : 'Pending' %>
              </span>
            </td>
            <td>
              <div style="display:flex;gap:var(--sp-2)">
                <button class="btn btn--ghost btn--icon-sm assign-owner-btn"
                  data-id="<%= r._id %>" data-name="<%= r.name %>"
                  data-owner-id="<%= r.owner ? r.owner._id : '' %>" title="Assign Owner">
                  <i class="fa-solid fa-user-tie" style="font-size:var(--text-xs)"></i>
                </button>
                <button class="btn btn--ghost btn--icon-sm edit-rest-btn"
                  data-id="<%= r._id %>" data-name="<%= r.name %>"
                  data-desc="<%= r.description %>" data-delivery="<%= r.deliveryTime %>"
                  data-approved="<%= r.isApproved %>" title="Edit">
                  <i class="fa-solid fa-pen" style="font-size:var(--text-xs)"></i>
                </button>
                <button class="btn btn--ghost btn--icon-sm delete-rest-btn"
                  data-id="<%= r._id %>" data-name="<%= r.name %>" title="Delete"
                  style="color:var(--clr-danger)">
                  <i class="fa-solid fa-trash" style="font-size:var(--text-xs)"></i>
                </button>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<!-- Add/Edit Restaurant Modal -->
<div class="modal-backdrop" id="rest-modal">
  <div class="modal">
    <div class="modal__header">
      <h2 class="modal__title" id="rest-modal-title">Add Restaurant</h2>
      <span class="modal__close" id="close-rest-modal"><i class="fa-solid fa-xmark"></i></span>
    </div>
    <form id="rest-form">
      <input type="hidden" id="rest-modal-id" />
      <div class="form-group">
        <label class="form-label">Restaurant Name</label>
        <input type="text" class="form-control" id="rest-name" required placeholder="e.g. Cinnabon" />
      </div>
      <div class="form-group">
        <label class="form-label">Description</label>
        <textarea class="form-control" id="rest-desc" rows="2" placeholder="Brief description…"></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Delivery Time</label>
        <input type="text" class="form-control" id="rest-delivery" placeholder="e.g. 15-20 mins" />
      </div>
      <div class="form-group">
        <label class="form-label">Approval Status</label>
        <select class="form-control" id="rest-approved">
          <option value="true">Approved</option>
          <option value="false">Pending</option>
        </select>
      </div>
      <div style="display:flex;gap:var(--sp-3);justify-content:flex-end;margin-top:var(--sp-4)">
        <button type="button" class="btn btn--ghost" id="cancel-rest-modal">Cancel</button>
        <button type="submit" class="btn btn--primary">Save Restaurant</button>
      </div>
    </form>
  </div>
</div>

<!-- Assign Owner Modal -->
<div class="modal-backdrop" id="assign-modal">
  <div class="modal">
    <div class="modal__header">
      <h2 class="modal__title">Assign Owner</h2>
      <span class="modal__close" id="close-assign-modal"><i class="fa-solid fa-xmark"></i></span>
    </div>
    <p style="color:var(--clr-text-3);margin-bottom:var(--sp-5);font-size:var(--text-sm)">
      Assign a restaurant owner to: <strong id="assign-rest-name"></strong>
    </p>
    <input type="hidden" id="assign-rest-id" />
    <div class="form-group">
      <label class="form-label">Select Owner</label>
      <select class="form-control" id="assign-owner-select">
        <option value="">— Remove Owner —</option>
        <% owners.forEach(o => { %>
          <option value="<%= o._id %>"><%= o.name %> (<%= o.email %>)</option>
        <% }) %>
      </select>
    </div>
    <div style="display:flex;gap:var(--sp-3);justify-content:flex-end;margin-top:var(--sp-4)">
      <button type="button" class="btn btn--ghost" id="cancel-assign-modal">Cancel</button>
      <button type="button" class="btn btn--primary" id="confirm-assign-btn">Assign</button>
    </div>
  </div>
</div>
