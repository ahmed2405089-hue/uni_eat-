<script src="/js/owner.js"></script>

<div class="page-header__row" data-anim>
  <div class="page-header">
    <a href="/owner/dashboard" class="btn btn--ghost btn--sm" style="margin-bottom:var(--sp-3)">
      <i class="fa-solid fa-arrow-left"></i> Dashboard
    </a>
    <h1 class="page-title">Manage Menu</h1>
    <p class="page-subtitle"><%= restaurant.name %></p>
  </div>
  <button class="btn btn--primary" id="add-item-btn">
    <i class="fa-solid fa-plus"></i> Add Item
  </button>
</div>

<!-- Toggle Open/Closed -->
<div class="card card--flat" style="margin-bottom:var(--sp-6);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--sp-4)" data-anim>
  <div>
    <div style="font-weight:700">Restaurant Status</div>
    <div style="font-size:var(--text-sm);color:var(--clr-text-muted)">
      Toggle whether your restaurant accepts orders right now.
    </div>
  </div>
  <button class="btn <%= restaurant.isOpen ? 'btn--danger' : 'btn--success' %>" id="toggle-open-btn"
    data-restaurant-id="<%= restaurant._id %>" data-is-open="<%= restaurant.isOpen %>">
    <i class="fa-solid fa-<%= restaurant.isOpen ? 'door-closed' : 'door-open' %>"></i>
    <%= restaurant.isOpen ? 'Mark as Closed' : 'Mark as Open' %>
  </button>
</div>

<!-- Menu Categories -->
<div class="menu-manager" id="menu-manager">
  <% if (!restaurant.categories || restaurant.categories.length === 0) { %>
    <div class="empty-state" data-anim>
      <i class="fa-solid fa-bowl-food"></i>
      <h3>No Menu Items Yet</h3>
      <p>Click "Add Item" to start building your menu.</p>
    </div>
  <% } else { %>
    <% restaurant.categories.forEach((cat, ci) => { %>
      <div class="category-section" data-anim style="animation-delay:<%= ci * 80 %>ms">
        <div class="category-section__head">
          <span class="category-section__name">
            <i class="fa-solid fa-tag" style="color:var(--clr-primary-l)"></i> <%= cat.name %>
            <span style="font-size:var(--text-xs);color:var(--clr-text-muted);font-weight:500">(<%= cat.items.length %> items)</span>
          </span>
          <button class="btn btn--ghost btn--sm add-to-category-btn" data-category="<%= cat.name %>">
            <i class="fa-solid fa-plus"></i> Add to Category
          </button>
        </div>
        <div class="category-section__body">
          <% if (cat.items.length === 0) { %>
            <p style="color:var(--clr-text-muted);font-size:var(--text-sm)">No items in this category.</p>
          <% } else { %>
            <% cat.items.forEach(item => { %>
              <div class="menu-item-row">
                <div class="menu-item-row__name">
                  <%= item.name %>
                  <% if (!item.isAvailable) { %>
                    <span class="badge badge--cancelled" style="font-size:10px;margin-left:var(--sp-2)">Unavailable</span>
                  <% } %>
                </div>
                <div class="menu-item-row__price">EGP <%= item.price.toFixed(2) %></div>
                <div class="menu-item-row__actions">
                  <button class="btn btn--ghost btn--icon-sm edit-item-btn"
                    data-item-id="<%= item._id %>" data-name="<%= item.name %>"
                    data-price="<%= item.price %>" data-category="<%= cat.name %>"
                    data-desc="<%= item.description || '' %>" title="Edit">
                    <i class="fa-solid fa-pen" style="font-size:var(--text-xs)"></i>
                  </button>
                  <button class="btn btn--ghost btn--icon-sm delete-item-btn"
                    data-item-id="<%= item._id %>" data-name="<%= item.name %>"
                    data-category="<%= cat.name %>" title="Delete"
                    style="color:var(--clr-danger)">
                    <i class="fa-solid fa-trash" style="font-size:var(--text-xs)"></i>
                  </button>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<!-- Add / Edit Item Modal -->
<div class="modal-backdrop" id="item-modal">
  <div class="modal">
    <div class="modal__header">
      <h2 class="modal__title" id="modal-title">Add Menu Item</h2>
      <span class="modal__close" id="close-modal"><i class="fa-solid fa-xmark"></i></span>
    </div>
    <form id="item-form">
      <input type="hidden" id="modal-item-id" />
      <div class="form-group">
        <label class="form-label">Category</label>
        <input type="text" class="form-control" id="modal-category" placeholder="e.g. Main Dishes, Drinks" list="categories-list" />
        <datalist id="categories-list">
          <% if (restaurant.categories) { restaurant.categories.forEach(c => { %>
            <option value="<%= c.name %>">
          <% }) } %>
        </datalist>
      </div>
      <div class="form-group">
        <label class="form-label">Item Name</label>
        <input type="text" class="form-control" id="modal-name" placeholder="e.g. Crispy Chicken Sandwich" required />
      </div>
      <div class="form-group">
        <label class="form-label">Price (EGP)</label>
        <input type="number" class="form-control" id="modal-price" placeholder="0.00" min="0" step="0.5" required />
      </div>
      <div class="form-group">
        <label class="form-label">Description (optional)</label>
        <textarea class="form-control" id="modal-desc" rows="2" placeholder="Brief description of the item"></textarea>
      </div>
      <div style="display:flex;gap:var(--sp-3);justify-content:flex-end;margin-top:var(--sp-4)">
        <button type="button" class="btn btn--ghost" id="cancel-modal">Cancel</button>
        <button type="submit" class="btn btn--primary" id="save-item-btn">
          Save Item
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  window.__RESTAURANT_ID__ = '<%= restaurant._id %>';
</script>
