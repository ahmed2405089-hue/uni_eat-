<aside class="sidebar" id="sidebar">
  <% if (typeof user !== 'undefined' && user) { %>

    <% if (user.role === 'admin') { %>
      <div class="sidebar__group">
        <div class="sidebar__label">Overview</div>
        <a href="/admin/dashboard"   class="sidebar__link" data-sidebar><i class="fa-solid fa-gauge-high"></i> Dashboard</a>
      </div>
      <div class="sidebar__group">
        <div class="sidebar__label">Management</div>
        <a href="/admin/restaurants" class="sidebar__link" data-sidebar><i class="fa-solid fa-store"></i> Restaurants</a>
        <a href="/admin/users"       class="sidebar__link" data-sidebar><i class="fa-solid fa-users"></i> Users</a>
        <a href="/admin/orders"      class="sidebar__link" data-sidebar><i class="fa-solid fa-receipt"></i> All Orders</a>
      </div>

    <% } else if (user.role === 'owner') { %>
      <div class="sidebar__group">
        <div class="sidebar__label">Overview</div>
        <a href="/owner/dashboard" class="sidebar__link" data-sidebar><i class="fa-solid fa-chart-line"></i> Dashboard</a>
      </div>
      <div class="sidebar__group">
        <div class="sidebar__label">Management</div>
        <a href="/owner/orders"   class="sidebar__link" data-sidebar><i class="fa-solid fa-receipt"></i> Orders</a>
      </div>

    <% } else { %>
      <div class="sidebar__group">
        <a href="/student/home"    class="sidebar__link" data-sidebar><i class="fa-solid fa-home"></i> Restaurants</a>
        <a href="/student/orders"  class="sidebar__link" data-sidebar><i class="fa-solid fa-receipt"></i> My Orders</a>
        <a href="/student/cart"    class="sidebar__link" data-sidebar><i class="fa-solid fa-cart-shopping"></i> Cart</a>
        <a href="/student/profile" class="sidebar__link" data-sidebar><i class="fa-solid fa-user"></i> Profile</a>
      </div>
    <% } %>

    <div style="margin-top:auto; padding-top: var(--sp-6); border-top: 1px solid var(--clr-border);">
      <div style="font-size: var(--text-sm); color: var(--clr-text-muted); margin-bottom: var(--sp-2);">Logged in as</div>
      <div style="font-weight:700; font-size: var(--text-sm)"><%= user.name %></div>
      <div style="font-size: var(--text-xs); color: var(--clr-text-muted)"><%= user.email %></div>
      <button class="btn btn--ghost btn--sm w-full mt-4" id="logout-btn" style="justify-content:flex-start">
        <i class="fa-solid fa-right-from-bracket"></i> Logout
      </button>
    </div>

  <% } %>
</aside>
