<link rel="stylesheet" href="/css/student.css" />
<script src="/js/student.js"></script>
<script src="/js/checkout.js"></script>

<div class="container" style="padding-top:var(--sp-10);padding-bottom:var(--sp-16)">
  <div class="page-header" data-anim>
    <a href="/student/cart" class="btn btn--ghost btn--sm" style="margin-bottom:var(--sp-4)">
      <i class="fa-solid fa-arrow-left"></i> Back to Cart
    </a>
    <h1 class="page-title">Checkout</h1>
    <p class="page-subtitle">Review your order and place it.</p>
  </div>

  <div id="checkout-empty" class="empty-state" style="display:none">
    <i class="fa-solid fa-cart-shopping"></i>
    <h3>Cart is empty</h3>
    <a href="/student/home" class="btn btn--primary mt-4">Browse Restaurants</a>
  </div>

  <div id="checkout-content" class="cart-page-layout">
    <div data-anim>
      <!-- Order Items Preview -->
      <div class="card card--flat" style="margin-bottom:var(--sp-6)">
        <h3 style="font-weight:700;margin-bottom:var(--sp-4)">
          <i class="fa-solid fa-receipt" style="color:var(--clr-primary-l)"></i> Order Items
        </h3>
        <div id="checkout-items"></div>
      </div>

      <!-- Special Instructions -->
      <div class="card card--flat">
        <h3 style="font-weight:700;margin-bottom:var(--sp-4)">
          <i class="fa-solid fa-comment-dots" style="color:var(--clr-accent-l)"></i> Special Instructions
        </h3>
        <div class="form-group" style="margin-bottom:0">
          <textarea class="form-control" id="order-comment" rows="3"
            placeholder="Any special requests? Allergies, spice level, etc."></textarea>
        </div>
      </div>
    </div>

    <!-- Summary + Place Order -->
    <div class="order-summary" data-anim>
      <h3>Order Summary</h3>
      <div id="checkout-summary-items" style="margin-bottom:var(--sp-4)"></div>
      <div class="summary-row"><span>Subtotal</span><span id="checkout-subtotal">EGP 0.00</span></div>
      <div class="summary-row"><span>Tax (5%)</span><span id="checkout-tax">EGP 0.00</span></div>
      <div class="summary-row total"><span>Total</span><span id="checkout-total">EGP 0.00</span></div>

      <div style="background:var(--clr-bg-3);border-radius:var(--r-md);padding:var(--sp-4);margin:var(--sp-5) 0;font-size:var(--text-sm);color:var(--clr-text-3)">
        <i class="fa-solid fa-info-circle" style="color:var(--clr-info)"></i>
        Payment is collected at pickup. Your order will be ready in
        <strong style="color:var(--clr-text)">15-30 minutes</strong>.
      </div>

      <button class="btn btn--accent w-full btn--lg" id="place-order-btn">
        <i class="fa-solid fa-check"></i>
        <span id="place-order-text">Place Order</span>
        <span id="place-order-spinner" class="spinner" style="display:none;width:18px;height:18px;border-width:2px"></span>
      </button>
    </div>
  </div>
</div>
