<link rel="stylesheet" href="/css/student.css" />
<script src="/js/student.js"></script>

<!-- Hero -->
<section class="hero">
  <div class="hero__orb hero__orb--1"></div>
  <div class="hero__orb hero__orb--2"></div>
  <div class="container" style="position:relative;z-index:1">
    <!-- Weather Widget (fetched from Open Meteo API) -->
    <div id="weather-widget" style="display:none;align-items:center;gap:var(--sp-3);background:rgba(255,255,255,.15);backdrop-filter:blur(8px);border-radius:var(--r-full);padding:var(--sp-2) var(--sp-5);width:fit-content;margin-bottom:var(--sp-5);font-size:var(--text-sm);color:#fff;border:1px solid rgba(255,255,255,.25)">
      <span id="w-icon" style="font-size:1.4rem">☀️</span>
      <span id="w-temp" style="font-weight:700">--°C</span>
      <span id="w-desc" style="opacity:.85">--</span>
      <span style="opacity:.6;font-size:var(--text-xs)">· Cairo Campus</span>
    </div>
    <h1 data-anim>What are you<br><span>hungry for</span> today?</h1>
    <p data-anim>Browse your campus restaurants and order your favorite meals.</p>
    <div class="hero__search" data-anim>
      <div class="hero__search-box">
        <i class="fa-solid fa-magnifying-glass" style="color:var(--clr-text-muted)"></i>
        <input type="text" id="search-input" placeholder="Search restaurants or food items…" />
        <button class="btn btn--primary btn--sm" id="search-btn" style="border-radius:var(--r-full);padding:10px 20px">
          Search
        </button>
      </div>
    </div>
  </div>
</section>

<!-- Filter Bar -->
<div class="container" style="padding-top:var(--sp-8)">
  <div class="filter-bar" data-anim>
    <span class="filter-chip active" data-filter="all"><i class="fa-solid fa-border-all"></i> All</span>
    <span class="filter-chip" data-filter="open"><i class="fa-solid fa-door-open"></i> Open Now</span>
    <span class="filter-chip" data-filter="top"><i class="fa-solid fa-star"></i> Top Rated</span>
    <span class="filter-chip" data-filter="fast"><i class="fa-solid fa-bolt"></i> Fast Delivery</span>
  </div>

  <!-- Restaurants Grid -->
  <div class="restaurants-grid" id="restaurants-grid">
    <% if (restaurants.length === 0) { %>
      <div class="empty-state" style="grid-column:1/-1">
        <i class="fa-solid fa-store-slash"></i>
        <h3>No Restaurants Found</h3>
        <p>Try a different search term.</p>
      </div>
    <% } else { %>
      <% restaurants.forEach((r, i) => { %>
        <a href="/student/restaurant/<%= r._id %>" class="restaurant-card" data-anim
           data-open="<%= r.isOpen %>" data-rating="<%= r.rating %>"
           style="animation-delay:<%= i * 60 %>ms">
          <div class="restaurant-card__img">
            <% if (r.image) { %>
              <img src="<%= r.image %>" alt="<%= r.name %>" loading="lazy" />
            <% } else { %>
              <div style="width:100%;height:100%;display:grid;place-items:center;font-size:3rem;background:var(--clr-bg-3)">🍽️</div>
            <% } %>
            <span class="restaurant-card__status restaurant-card__status--<%= r.isOpen ? 'open' : 'closed' %>">
              <%= r.isOpen ? '● Open' : '● Closed' %>
            </span>
          </div>
          <div class="restaurant-card__body">
            <% if (r.tags && r.tags.length) { %>
              <div class="restaurant-card__tags">
                <% r.tags.slice(0,3).forEach(tag => { %><span class="tag"><%= tag %></span><% }) %>
              </div>
            <% } %>
            <h3 class="restaurant-card__name"><%= r.name %></h3>
            <p class="restaurant-card__desc"><%= r.description || 'Delicious campus food awaits.' %></p>
            <div class="restaurant-card__meta">
              <span class="restaurant-card__rating">
                <i class="fa-solid fa-star"></i>
                <%= r.rating ? r.rating.toFixed(1) : 'New' %>
              </span>
              <span><i class="fa-regular fa-clock"></i> <%= r.deliveryTime %></span>
            </div>
          </div>
        </a>
      <% }) %>
    <% } %>
  </div>

  <div id="no-results" class="empty-state" style="display:none">
    <i class="fa-solid fa-magnifying-glass"></i>
    <h3>No Results Found</h3>
    <p>Try different keywords.</p>
  </div>

  <% if (pages > 1) { %>
    <div class="pagination" style="display:flex;justify-content:center;align-items:center;gap:var(--sp-2);padding:var(--sp-8) 0" data-anim>
      <% if (page > 1) { %>
        <a href="?page=<%= page - 1 %>" class="btn btn--ghost btn--sm">
          <i class="fa-solid fa-chevron-left"></i> Prev
        </a>
      <% } %>
      <% for (let i = 1; i <= pages; i++) { %>
        <a href="?page=<%= i %>" class="btn btn--sm <%= i === page ? 'btn--primary' : 'btn--ghost' %>">
          <%= i %>
        </a>
      <% } %>
      <% if (page < pages) { %>
        <a href="?page=<%= page + 1 %>" class="btn btn--ghost btn--sm">
          Next <i class="fa-solid fa-chevron-right"></i>
        </a>
      <% } %>
      <span style="font-size:var(--text-xs);color:var(--clr-text-muted);margin-left:var(--sp-3)">
        <%= total %> restaurant<%= total !== 1 ? 's' : '' %>
      </span>
    </div>
  <% } %>
</div>

<div style="padding-bottom:var(--sp-16)"></div>

<script>
  window.__RESTAURANTS__ = <%- JSON.stringify(restaurants.map(r => ({
    id: r._id, name: r.name, description: r.description,
    isOpen: r.isOpen, rating: r.rating, tags: r.tags
  }))) %>;

  /* ── External API: Open Meteo weather for Cairo campus ── */
  (async () => {
    try {
      const resp = await fetch(
        'https://api.open-meteo.com/v1/forecast?latitude=30.05&longitude=31.24' +
        '&current=temperature_2m,weathercode,windspeed_10m&timezone=Africa%2FCairo',
        { signal: AbortSignal.timeout(5000) }
      );
      if (!resp.ok) return;
      const { current } = await resp.json();
      const code = current.weathercode;
      const iconMap = (c) => {
        if (c === 0)          return ['☀️', 'Clear Sky'];
        if (c <= 3)           return ['⛅', 'Partly Cloudy'];
        if (c <= 48)          return ['🌫️', 'Foggy'];
        if (c <= 55)          return ['🌦️', 'Drizzle'];
        if (c <= 67)          return ['🌧️', 'Rainy'];
        if (c <= 82)          return ['🌦️', 'Showers'];
        if (c <= 86)          return ['❄️', 'Snow'];
        return ['⛈️', 'Storm'];
      };
      const [icon, desc] = iconMap(code);
      document.getElementById('w-icon').textContent = icon;
      document.getElementById('w-temp').textContent = `${Math.round(current.temperature_2m)}°C`;
      document.getElementById('w-desc').textContent = desc;
      document.getElementById('weather-widget').style.display = 'flex';
    } catch { /* widget stays hidden if API unavailable */ }
  })();
</script>
