<div class="auth-card animate-slide">
  <a href="/" class="auth-logo">
    <div class="auth-logo__icon">🍽️</div>
    <span class="auth-logo__text">Uni<span>Eats</span></span>
  </a>

  <div class="auth-header">
    <h1>Reset password</h1>
    <p>Enter your email and we'll send you a reset link.</p>
  </div>

  <div id="auth-alert" style="display:none" class="auth-alert"></div>

  <form id="forgot-form" novalidate>
    <div class="form-group">
      <label class="form-label">Email Address</label>
      <div class="input-icon-wrap">
        <i class="fa-solid fa-envelope icon-left"></i>
        <input type="email" id="email" name="email" class="form-control"
               placeholder="you@university.edu" required />
      </div>
    </div>
    <button type="submit" class="btn btn--primary w-full" id="forgot-btn">
      Send Reset Link <i class="fa-solid fa-paper-plane"></i>
    </button>
  </form>

  <p class="auth-footer"><a href="/auth/login">Back to Login</a></p>
</div>
