<link rel="stylesheet" href="/css/student.css" />

<!-- Hero -->
<section class="hero">
  <div class="hero__orb hero__orb--1"></div>
  <div class="hero__orb hero__orb--2"></div>
  <div class="container" style="position:relative;z-index:1;">
    <div class="hero__badge" data-anim>
      <i class="fa-solid fa-bolt"></i> Fast Campus Delivery
    </div>
    <h1 data-anim>
      Order Food From<br>Your Campus<br><span>Restaurants</span>
    </h1>
    <p data-anim>Discover and order from the best restaurants on your university campus. Fresh food, real-time tracking, hassle-free.</p>

    <div class="hero__search" data-anim>
      <div class="hero__search-box">
        <i class="fa-solid fa-magnifying-glass" style="color:var(--clr-text-muted)"></i>
        <input type="text" placeholder="Search restaurants or dishes…" id="hero-search" />
        <a href="/student/home" class="btn btn--primary btn--sm" style="border-radius:var(--r-full); padding: 10px 20px">
          Explore <i class="fa-solid fa-arrow-right"></i>
        </a>
      </div>
    </div>

    <div class="hero__stats" data-anim>
      <div>
        <div class="hero__stat-num"><%= restaurants.length %>+</div>
        <div class="hero__stat-label">Restaurants</div>
      </div>
      <div>
        <div class="hero__stat-num">1k+</div>
        <div class="hero__stat-label">Happy Students</div>
      </div>
      <div>
        <div class="hero__stat-num">5min</div>
        <div class="hero__stat-label">Avg Prep Time</div>
      </div>
    </div>
  </div>
</section>

<!-- Featured Restaurants -->
<section class="section">
  <div class="container">
    <div class="page-header__row" data-anim>
      <div>
        <h2 style="font-size:var(--text-3xl);font-weight:800;letter-spacing:-.5px">
          Featured <span class="text-primary">Restaurants</span>
        </h2>
        <p class="text-muted mt-4">Top-rated campus restaurants — fresh food every day</p>
      </div>
      <a href="/student/home" class="btn btn--outline">
        View All <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>

    <% if (restaurants.length > 0) { %>
      <div class="restaurants-grid mt-6">
        <% restaurants.forEach((r, i) => { %>
          <a href="<%= user ? '/student/restaurant/' + r._id : '/auth/login' %>"
             class="restaurant-card" data-anim style="animation-delay: <%= i * 80 %>ms">
            <div class="restaurant-card__img">
              <% if (r.image) { %>
                <img src="<%= r.image %>" alt="<%= r.name %>" loading="lazy" />
              <% } else { %>
                <div style="width:100%;height:100%;display:grid;place-items:center;font-size:3rem;background:var(--clr-bg-3);color:var(--clr-text-muted)">🍽️</div>
              <% } %>
              <span class="restaurant-card__status restaurant-card__status--<%= r.isOpen ? 'open' : 'closed' %>">
                <%= r.isOpen ? '● Open' : '● Closed' %>
              </span>
            </div>
            <div class="restaurant-card__body">
              <% if (r.tags && r.tags.length) { %>
                <div class="restaurant-card__tags">
                  <% r.tags.slice(0,3).forEach(tag => { %><span class="tag"><%= tag %></span><% }) %>
                </div>
              <% } %>
              <h3 class="restaurant-card__name"><%= r.name %></h3>
              <p class="restaurant-card__desc"><%= r.description || 'Delicious campus food awaits.' %></p>
              <div class="restaurant-card__meta">
                <span class="restaurant-card__rating">
                  <i class="fa-solid fa-star"></i> <%= r.rating ? r.rating.toFixed(1) : 'New' %>
                </span>
                <span><i class="fa-solid fa-clock"></i> <%= r.deliveryTime %></span>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state" data-anim>
        <i class="fa-solid fa-store-slash"></i>
        <h3>No Restaurants Yet</h3>
        <p>Check back soon — restaurants are being added.</p>
      </div>
    <% } %>
  </div>
</section>

<!-- How It Works -->
<section class="section" style="background:var(--clr-bg-2); border-top:1px solid var(--clr-border);border-bottom:1px solid var(--clr-border);">
  <div class="container">
    <div class="text-center mb-6" data-anim>
      <h2 style="font-size:var(--text-3xl);font-weight:800;letter-spacing:-.5px">How It <span class="text-primary">Works</span></h2>
      <p class="text-muted mt-4">Three simple steps to get your food</p>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:var(--sp-8)">
      <% const steps = [
        { icon: '🔍', num: '01', title: 'Browse Restaurants', desc: 'Explore campus restaurants and their menus.' },
        { icon: '🛒', num: '02', title: 'Add to Cart',        desc: 'Pick your favorite dishes and customise your order.' },
        { icon: '🚀', num: '03', title: 'Track in Real Time', desc: 'Follow your order status live from preparation to pickup.' },
      ]; %>
      <% steps.forEach((s, i) => { %>
        <div class="card card--glow" data-anim style="animation-delay:<%= i * 120 %>ms;text-align:center">
          <div style="font-size:2.8rem;margin-bottom:var(--sp-4)"><%= s.icon %></div>
          <div style="font-size:var(--text-xs);font-weight:800;letter-spacing:2px;color:var(--clr-text-muted);margin-bottom:var(--sp-2)"><%= s.num %></div>
          <h3 style="font-size:var(--text-lg);font-weight:700;margin-bottom:var(--sp-3);color:var(--clr-text)"><%= s.title %></h3>
          <p style="font-size:var(--text-sm);color:var(--clr-text-3)"><%= s.desc %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="section">
  <div class="container">
    <div class="card" data-anim style="text-align:center;background:linear-gradient(135deg,#fff8ee,rgba(249,115,22,.06));border-color:rgba(249,115,22,.2);padding:var(--sp-16)">
      <div style="font-size:3rem;margin-bottom:var(--sp-4)">🎓</div>
      <h2 style="font-size:var(--text-4xl);font-weight:900;letter-spacing:-1px;margin-bottom:var(--sp-4)">
        Ready to Order?
      </h2>
      <p class="text-muted" style="font-size:var(--text-lg);max-width:480px;margin:0 auto var(--sp-8)">
        Join thousands of students already enjoying campus food delivered in minutes.
      </p>
      <div style="display:flex;gap:var(--sp-4);justify-content:center;flex-wrap:wrap">
        <a href="/auth/register" class="btn btn--primary btn--lg">
          <i class="fa-solid fa-user-plus"></i> Get Started Free
        </a>
        <a href="/student/home" class="btn btn--outline btn--lg">
          <i class="fa-solid fa-compass"></i> Browse Restaurants
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const heroSearch = document.getElementById('hero-search');
  if (heroSearch) {
    heroSearch.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        window.location.href = `/student/home?search=${encodeURIComponent(heroSearch.value.trim())}`;
      }
    });
  }
</script>
