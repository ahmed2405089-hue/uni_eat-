<div style="min-height:70vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:var(--sp-8)">
  <div class="animate-scale">
    <div style="font-size:6rem;margin-bottom:var(--sp-4)">
      <%= statusCode === 404 ? '🔍' : statusCode === 403 ? '🚫' : '⚠️' %>
    </div>
    <h1 style="font-size:var(--text-5xl);font-weight:900;color:var(--clr-primary-l);margin-bottom:var(--sp-3)">
      <%= statusCode || 500 %>
    </h1>
    <h2 style="font-size:var(--text-2xl);font-weight:700;margin-bottom:var(--sp-4)">
      <%= statusCode === 404 ? 'Page Not Found' : statusCode === 403 ? 'Access Denied' : 'Something Went Wrong' %>
    </h2>
    <p style="color:var(--clr-text-3);max-width:400px;margin:0 auto var(--sp-8)">
      <%= message || 'An unexpected error occurred.' %>
    </p>
    <% if (typeof stack !== 'undefined' && stack) { %>
      <pre style="text-align:left;background:var(--clr-bg-2);border:1px solid var(--clr-border);border-radius:var(--r-md);padding:var(--sp-4);font-size:var(--text-xs);color:var(--clr-text-muted);max-width:700px;overflow-x:auto;margin:0 auto var(--sp-8)"><%= stack %></pre>
    <% } %>
    <div style="display:flex;gap:var(--sp-4);justify-content:center;flex-wrap:wrap">
      <a href="/" class="btn btn--primary"><i class="fa-solid fa-home"></i> Go Home</a>
      <button onclick="history.back()" class="btn btn--outline">
        <i class="fa-solid fa-arrow-left"></i> Go Back
      </button>
    </div>
  </div>
</div>
